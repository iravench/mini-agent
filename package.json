{
  "name": "mini-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "fix": "eslint --fix src/ tests/ && prettier --write src/ tests/",
    "check": "tsc --noEmit && eslint src/ tests/ && prettier --check src/ tests/"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.63.0",
    "@mariozechner/pi-ai": "^0.63.0",
    "chalk": "^5.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "safe-buffer": "npm:@socketregistry/safe-buffer@^1"
  }
}
